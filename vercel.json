{
  "version": 2,
  "builds": [
    {
      "src": "server/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "client/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/vagas(.*)",
      "dest": "server/server.ts"
    },
    {
      "src": "/candidaturas(.*)",
      "dest": "server/server.ts"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1"
    }
  ]
}
